{
  "name": "blue-steel-mcp",
  "version": "0.1.3",
  "description": "MCP server for Blue Steel browser automation",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "bin": {
    "blue-steel-mcp": "dist/index.js"
  },
  "exports": {
    "require": {
      "types": "./dist/index.d.cts",
      "default": "./dist/index.cjs"
    },
    "import": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blue-steeldev/blue-steel.git"
  },
  "homepage": "https://github.com/blue-steeldev/blue-steel#readme",
  "bugs": {
    "url": "https://github.com/blue-steeldev/blue-steel/issues"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "blue-steel",
    "browser-automation",
    "ai",
    "agent",
    "testing"
  ],
  "scripts": {
    "build": "pkgroll",
    "check": "tsc --noEmit",
    "inspector": "npx @modelcontextprotocol/inspector dist/index.js"
  },
  "author": {
    "name": "BlueSteel",
    "email": "founders@blue-steel.run",
    "url": "https://blue-steel.run"
  },
  "contributors": [
    "Anders Lie <anders@blue-steel.run>",
    "Tom Greenwald <tom@blue-steel.run>"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.0",
    "blue-steel-core": "workspace:*",
    "zod": "^3.24.2",
    "zod-to-json-schema": "^3.24.5"
  },
  "devDependencies": {
    "@types/node": "^20.17.30",
    "pkgroll": "^2.15.4",
    "typescript": "^5.8.3"
  }
}
