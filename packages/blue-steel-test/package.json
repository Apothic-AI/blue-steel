{
  "name": "blue-steel-test",
  "version": "0.3.13",
  "description": "A TypeScript client for running automated UI tests through the Blue Steel testing platform",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "bin": {
    "blue-steel": "dist/cli.js"
  },
  "exports": {
    "require": {
      "types": "./dist/index.d.cts",
      "default": "./dist/index.cjs"
    },
    "import": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blue-steeldev/blue-steel.git"
  },
  "homepage": "https://github.com/blue-steeldev/blue-steel#readme",
  "bugs": {
    "url": "https://github.com/blue-steeldev/blue-steel/issues"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pkgroll",
    "check": "tsc --noEmit || true",
    "cli": "bun src/cli.ts",
    "cli-bin": "bun dist/cli.js",
    "pubdev": "bun run build && yalc publish --force --push"
  },
  "keywords": [
    "testing",
    "ui-testing",
    "automation",
    "blue-steel",
    "typescript"
  ],
  "author": {
    "name": "BlueSteel",
    "email": "founders@blue-steel.run",
    "url": "https://blue-steel.run"
  },
  "contributors": [
    "Anders Lie <anders@blue-steel.run>",
    "Tom Greenwald <tom@blue-steel.run>"
  ],
  "license": "Apache-2.0",
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^22.13.4",
    "@types/react": "^18.2.0",
    "pkgroll": "^2.10.0",
    "typescript": "~5.7.2"
  },
  "dependencies": {
    "@commander-js/extra-typings": "^14.0.0",
    "@paralleldrive/cuid2": "^2.2.2",
    "@types/terminal-kit": "^2.5.7",
    "blue-steel-core": "workspace:*",
    "chalk": "^5.4.1",
    "commander": "^14.0.0",
    "dotenv": "^16.5.0",
    "esbuild": "^0.25.1",
    "eventemitter3": "^5.0.4",
    "glob": "^11.0.1",
    "jiti": "^2.4.2",
    "log-update": "^6.1.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "posthog-node": "^4.18.0",
    "std-env": "^3.9.0",
    "zod": "^3.24.2"
  }
}
