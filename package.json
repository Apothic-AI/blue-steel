{
  "name": "blue-steel",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish",
    "postinstall": "echo 'Blue Steel: run bootstrap in skill/ and bun install in packages as needed'"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.28.1",
    "prettier": "^3.5.3",
    "turbo": "^2.4.4",
    "typescript": "5.8.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.2.8^",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "author": {
    "name": "BlueSteel",
    "url": "https://github.com/bitnom/blue-steel"
  },
  "contributors": [],
  "license": "Apache-2.0"
}
