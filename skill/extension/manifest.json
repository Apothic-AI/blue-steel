{
  "manifest_version": 2,
  "name": "Camoufox Container Bridge",
  "version": "0.1.0",
  "description": "Exposes Firefox contextual identity tab creation to Camoufox automation.",
  "applications": {
    "gecko": {
      "id": "camoufox-containers@ailb.local"
    }
  },
  "permissions": [
    "contextualIdentities",
    "cookies",
    "management",
    "tabs",
    "<all_urls>"
  ],
  "web_accessible_resources": [
    "bridge.html"
  ]
}
